{
  "expo": {
    "name": "FuseHarbor",
    "slug": "fuseharbor",
    "scheme": "fuseharbor",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#f7f4ee"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "org.fuseharbor.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "org.fuseharbor.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#f7f4ee"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": false
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "2d783cac-0c1a-47d7-9b77-e7ff9a1a07bd"
      }
    },
    "owner": "djimean"
  }
}
